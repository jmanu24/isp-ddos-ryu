{
  "title": "ISP DDoS Controller",
  "uid": "isp-ddos-controller",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Switch packet rate (pkt/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sdn_switch_packet_rate",
          "legendFormat": "switch {{dpid}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Switch byte rate (B/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sdn_switch_byte_rate",
          "legendFormat": "switch {{dpid}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Port RX/TX packets (cumulative)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sdn_port_rx_packets_total",
          "legendFormat": "rx sw{{dpid}} port{{port}}",
          "refId": "A"
        },
        {
          "expr": "sdn_port_tx_packets_total",
          "legendFormat": "tx sw{{dpid}} port{{port}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 4,
      "title": "Port drops (cumulative)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sdn_port_rx_dropped_total",
          "legendFormat": "rx-drop sw{{dpid}} port{{port}}",
          "refId": "A"
        },
        {
          "expr": "sdn_port_tx_dropped_total",
          "legendFormat": "tx-drop sw{{dpid}} port{{port}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "title": "Attacks detected (rate, by type)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(ddos_attacks_detected_total[1m])",
          "legendFormat": "{{attack_type}} ({{domain}})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Mitigations applied (rate, by type)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(ddos_mitigations_applied_total[1m])",
          "legendFormat": "{{action}}: {{attack_type}} ({{domain}})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Active blocks",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "ddos_active_blocks",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  }
}
