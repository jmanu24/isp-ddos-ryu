{
  "title": "ISP DDoS Controller",
  "uid": "isp-ddos-controller",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "1. Byte rate por puerto en cada switch",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(sdn_port_rx_bytes_total[1m])",
          "legendFormat": "rx sw{{dpid}} port{{port}}",
          "refId": "A"
        },
        {
          "expr": "rate(sdn_port_tx_bytes_total[1m])",
          "legendFormat": "tx sw{{dpid}} port{{port}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "title": "2. Packet rate por puerto en cada switch",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(sdn_port_rx_packets_total[1m])",
          "legendFormat": "rx sw{{dpid}} port{{port}}",
          "refId": "A"
        },
        {
          "expr": "rate(sdn_port_tx_packets_total[1m])",
          "legendFormat": "tx sw{{dpid}} port{{port}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "3. Byte rate por switch, por protocolo (TCP/UDP/ICMP)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sdn_switch_protocol_byte_rate",
          "legendFormat": "sw{{dpid}} {{protocol}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "4. Packet rate por switch, por protocolo (TCP/UDP/ICMP)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sdn_switch_protocol_packet_rate",
          "legendFormat": "sw{{dpid}} {{protocol}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "5. Ataques detectados (byte rate por tipo)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "ddos_attack_byte_rate",
          "legendFormat": "{{attack_type}} ({{domain}})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "6. Mitigaciones activadas (byte rate por tipo)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "ddos_mitigation_byte_rate",
          "legendFormat": "{{action}}: {{attack_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "7. Ataques detectados (packet rate por tipo)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "ddos_attack_packet_rate",
          "legendFormat": "{{attack_type}} ({{domain}})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "8. Mitigaciones activadas (packet rate por tipo)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "ddos_mitigation_packet_rate",
          "legendFormat": "{{action}}: {{attack_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "9. Numero de bloqueos activos",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "ddos_active_blocks",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "11. Top 10 origenes de ataques (por cantidad de bloqueos)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "targets": [
        {
          "expr": "topk(10, ddos_blocks_by_source_total)",
          "legendFormat": "{{src_ip}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 12,
      "title": "12. Top 10 destinos de ataques (por cantidad de bloqueos)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "targets": [
        {
          "expr": "topk(10, ddos_blocks_by_destination_total)",
          "legendFormat": "{{dst_ip}}",
          "refId": "A",
          "instant": true
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  }
}
